# ATENDE.IA — variáveis de ambiente.
# Copie este arquivo para ".env" e preencha com os valores reais do seu Supabase.
# NUNCA versione o arquivo ".env" (ele já está no .gitignore).

# Porta única onde o backend roda E serve o frontend.
PORT=8080
NODE_ENV=development

# --- Supabase ---
# Project Settings > API
SUPABASE_URL=
# Chave pública "anon" — usada para login (Supabase Auth) e para requisições com RLS.
SUPABASE_ANON_KEY=
# Chave SECRETA "service_role" — super-admin, ignora RLS.
# Fica SÓ no servidor, usada apenas em operações administrativas. Nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=
