# ATENDE.IA — variáveis de ambiente.
# Copie este arquivo para ".env" e preencha com os valores reais do seu Supabase.
# NUNCA versione o arquivo ".env" (ele já está no .gitignore).

# Porta única onde o backend roda E serve o frontend.
PORT=8080
NODE_ENV=development

# --- Supabase ---
# Project Settings > API
SUPABASE_URL=
# Chave pública "anon" — usada para login (Supabase Auth) e para requisições com RLS.
SUPABASE_ANON_KEY=
# Chave SECRETA "service_role" — super-admin, ignora RLS.
# Fica SÓ no servidor, usada apenas em operações administrativas. Nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=

# --- URL pública do app (necessária para OAuth e Webhook do Instagram) ---
# Em dev, use o túnel do ngrok (ex.: https://abc123.ngrok-free.app). SEM barra no fim.
APP_BASE_URL=

# Chave de criptografia dos tokens guardados no banco (AES-256-GCM).
# Gere uma de 32 bytes:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# --- Instagram (Meta) — "Instagram API with Instagram Login" ---
# developers.facebook.com > seu App > produto Instagram > "API setup with Instagram login".
IG_APP_ID=
IG_APP_SECRET=
# Token que VOCÊ inventa e cadastra no painel de Webhooks da Meta (qualquer string secreta).
IG_WEBHOOK_VERIFY_TOKEN=
# (Opcional) sobrescreve as permissões pedidas no login. Padrão já cobre mensagens.
# IG_SCOPES=instagram_business_basic,instagram_business_manage_messages

# --- Facebook Messenger (Meta) ---
# Mesmo App da Meta (App Settings > Basic). Se o App for o mesmo do Instagram,
# pode repetir os valores; se forem apps separados, use os do app do Facebook.
FB_APP_ID=
FB_APP_SECRET=
# Token que VOCÊ inventa e cadastra no Webhook de "Messenger" na Meta.
FB_WEBHOOK_VERIFY_TOKEN=
# (Opcional) sobrescreve as permissões pedidas no login do Facebook.
# FB_SCOPES=pages_show_list,pages_messaging,pages_manage_metadata,pages_read_engagement,business_management

# --- WhatsApp Cloud API (Meta) — conexão MANUAL ---
# A empresa informa o Phone Number ID + token na própria tela de Integrações.
# Aqui só precisa do verify token do Webhook de "WhatsApp" (a assinatura usa FB_APP_SECRET).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Google Calendar (OAuth 2.0) ---
# console.cloud.google.com > APIs e Serviços > Credenciais > ID do cliente OAuth (Aplicativo Web).
# Ative a "Google Calendar API" e adicione o redirect: <APP_BASE_URL>/api/integracoes/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# (Opcional) fuso usado ao criar eventos. Padrão: America/Sao_Paulo
# GOOGLE_TIMEZONE=America/Sao_Paulo
